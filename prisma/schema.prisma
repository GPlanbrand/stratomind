// Prisma Schema for 灵思AI创意工作台
// 数据库：Vercel Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户系统 ====================

model User {
  id              String    @id @default(uuid())
  username        String    @unique @db.VarChar(50)
  email           String    @unique @db.VarChar(100)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  avatar          String?   @db.VarChar(500)
  
  // 会员相关
  memberLevel     String    @default("normal") @map("member_level") @db.VarChar(20) // normal, silver, gold, diamond
  memberExpiresAt DateTime? @map("member_expires_at")
  
  // 积分
  points          Int       @default(0)
  
  // 签到
  signInDays      Int       @default(0) @map("sign_in_days")
  lastSignInDate  DateTime? @map("last_sign_in_date") @db.Date
  
  // 邀请
  inviteCode      String    @unique @map("invite_code") @db.VarChar(20)
  invitedBy       String?   @map("invited_by")
  
  // 时间戳
  createdAt       DateTime  @default(now()) @map("created_at")
  lastLoginAt     DateTime? @map("last_login_at")
  deletedAt       DateTime? @map("deleted_at")

  // 关联
  projects            Project[]
  pointsTransactions  PointsTransaction[]

  @@map("users")
}

// ==================== 项目系统 ====================

model Project {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String    @db.VarChar(200)
  clientName String    @map("client_name") @db.VarChar(200)
  status     String    @default("active") @db.VarChar(20) // active, completed, archived
  
  // 时间戳
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // 关联
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps ProjectStep?

  @@index([userId])
  @@map("projects")
}

// 项目步骤数据
model ProjectStep {
  id           String   @id @default(uuid())
  projectId    String   @unique @map("project_id")
  
  // 五步骤数据（JSON格式）
  clientInfo   Json?    @map("client_info")    // ClientInfo
  requirements Json?    @map("requirements")   // Requirements
  competitors  Json?    @map("competitors")    // Competitor[]
  brief        Json?    @map("brief")          // Brief
  strategy     Json?    @map("strategy")       // Strategy
  
  // 时间戳
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 关联
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_steps")
}

// ==================== 积分系统 ====================

model PointsTransaction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  
  // 交易类型
  type         String   @db.VarChar(20) // earn(获得), spend(消耗), expire(过期)
  amount       Int                                    // 数量（正/负）
  balanceAfter Int      @map("balance_after")         // 操作后余额
  
  // 来源
  source       String   @db.VarChar(50) // register, signIn, invite, feature, recharge
  description  String?  @db.Text
  
  // 时间戳
  createdAt    DateTime @default(now()) @map("created_at")

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("points_transactions")
}

// ==================== AI调用记录 ====================

model AiUsageLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  projectId    String?  @map("project_id")
  
  // 调用信息
  feature      String   @db.VarChar(50) // analyzeCompetitors, generateBrief, generateStrategy, generatePrompt
  inputData    Json?    @map("input_data")
  outputData   Json?    @map("output_data")
  
  // 消耗
  modelUsed    String?  @map("model_used") @db.VarChar(100)
  tokensUsed   Int?     @map("tokens_used")
  pointsCost   Int      @default(0) @map("points_cost")
  
  // 状态
  status       String   @default("success") @db.VarChar(20) // success, failed
  errorMessage String?  @map("error_message") @db.Text
  
  // 耗时
  durationMs   Int?     @map("duration_ms")
  
  // 时间戳
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([projectId])
  @@map("ai_usage_logs")
}


// ==================== 资产库 ====================

model Asset {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  projectId   String?   @map("project_id")
  
  // 资产信息
  name        String    @db.VarChar(200)
  type        String    @db.VarChar(20) // document, image, video, audio, other
  fileUrl     String    @map("file_url") @db.VarChar(500)
  fileSize    Int       @default(0) @map("file_size")
  
  // 元数据
  tags        String[]  @default([])
  description String?   @db.Text
  downloadCount Int     @default(0) @map("download_count")
  isPublic    Boolean   @default(false) @map("is_public")
  
  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([userId])
  @@index([projectId])
  @@map("assets")
}

// ==================== 知识库 ====================

model Knowledge {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  
  // 内容信息
  title       String    @db.VarChar(200)
  content     String    @db.Text
  category    String    @db.VarChar(20) // methodology(方法论), case(案例), template(模板), material(素材)
  
  // 元数据
  tags        String[]  @default([])
  viewCount   Int       @default(0) @map("view_count")
  isPublic    Boolean   @default(false) @map("is_public")
  
  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([userId])
  @@index([category])
  @@map("knowledge")
}
