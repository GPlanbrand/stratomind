// Prisma Schema for StratoMind

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  phone         String?   @unique
  password      String
  nickname      String?
  isPaid        Boolean   @default(false)
  paidExpireAt  DateTime?
  role          String    @default("user")
  avatar        String?
  memberLevel   String    @default("normal")
  points        Int       @default(600)
  totalRecharge Float     @default(0)
  memberExpiresAt DateTime?
  province      String?
  city          String?
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  signInDays    Int       @default(0)
  lastSignInDate String?
  inviteCode    String    @unique
  invitedBy     String?
  
  // Relations
  projects      Project[]
  aiLogs        AILog[]
  assets        Asset[]
  knowledgeItems KnowledgeItem[]
  pointsLogs    PointsLog[]
  rechargeRecords RechargeRecord[]
  adminLogs     AdminLog[]
  requirementSheets RequirementSheet[]
  userActionLogs UserActionLog[]
  messages      Message[]
  
  createdAt2    DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("users")
}

// 项目模型
model Project {
  id          String   @id @default(cuid())
  name        String
  clientName  String
  status      String   @default("active")
  userId      String
  
  // Project step data (JSON storage)
  clientInfo   String?
  requirements String?
  competitors  String?
  brief       String?
  strategy    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("projects")
}

// AI日志
model AILog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  input       String
  output      String?
  pointsCost  Int      @default(0)
  status      String   @default("success")
  error       String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("ai_logs")
}

// 资产库
model Asset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  url         String?
  size        Int?
  mimeType    String?
  metadata    String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("assets")
}

// 知识库
model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  category    String?
  tags        String?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("knowledge_items")
}

// 积分流水记录
model PointsLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Int
  balance     Int
  reason      String
  orderNo     String?
  adminId     String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("points_logs")
}

// 充值记录
model RechargeRecord {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  points      Int
  paymentMethod String
  status      String   @default("pending")
  orderNo     String?
  remark      String?
  operatorId  String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("recharge_records")
}

// 管理员操作日志
model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  adminName   String
  action      String
  targetType  String
  targetId    String?
  detail      String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  
  @@map("admin_logs")
}

// 用户操作日志
model UserActionLog {
  id          String   @id @default(cuid())
  userId      String
  actionType  String
  targetType  String
  targetId    String?
  targetName  String?
  metadata    String?
  ip          String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_action_logs")
}

// 需求确认单
model RequirementSheet {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  projectName String?  // 项目名称
  clientName  String?  // 客户名称
  title       String
  content     String
  items       String?  // 需求项列表(JSON数组存储)
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("requirement_sheets")
}

// =============================================
// 灵思智能体 - 消息系统
// =============================================

// 消息模型
model Message {
  id          String   @id @default(cuid())
  userId      String   // 接收用户
  title       String   // 消息标题
  content     String   // 消息内容
  type        String   // system/project/reminder/news/tip
  link        String?  // 跳转链接
  isRead      Boolean  @default(false)
  priority    String   @default("normal") // low/normal/high
  metadata    String?  // 额外数据(JSON)
  senderId    String?  // 发送者ID(系统为null或'system')
  createdAt   DateTime @default(now())
  readAt      DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("messages")
}

// 定时任务配置
model ScheduledTask {
  id          String   @id @default(cuid())
  name        String   // 任务名称
  type        String   // news_digest/reminder/weekly_report/custom
  cron        String   // Cron表达式
  config      String   // 任务配置(JSON)
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@map("scheduled_tasks")
}

// 灵思Profile配置
model LingsiProfile {
  id          String   @id @default(cuid())
  name        String   @default("灵思")
  avatar      String?  // 头像URL
  title       String   @default("您的智能创意伙伴")
  description String?  // 简介
  greeting    String?  // 欢迎语
  systemPrompt String? // 系统提示词
  settings    String?  // 个性化设置(JSON)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("lingsi_profiles")
}


// =============================================
// 访客会话模型
// =============================================
model GuestSession {
  id        String   @id @default(cuid())
  token     String   @unique
  data      String?  // 访客数据(JSON存储)
  expireAt  DateTime
  createdAt DateTime @default(now())
  
  @@index([token])
  @@map("guest_sessions")
}

// =============================================
// 短信验证码模型
// =============================================
model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      String   @default("login") // login/register/reset
  used      Boolean  @default(false)
  expireAt  DateTime
  createdAt DateTime @default(now())
  
  @@index([phone, createdAt])
  @@map("sms_codes")
}
