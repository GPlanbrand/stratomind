// Prisma Schema for StratoMind

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  phone         String?   @unique
  password      String
  nickname      String?
  isPaid        Boolean   @default(false)
  paidExpireAt  DateTime?
  role          String    @default("user")
  avatar        String?
  memberLevel   String    @default("normal")
  points        Int       @default(600)
  totalRecharge Float     @default(0)
  memberExpiresAt DateTime?
  province      String?
  city          String?
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  signInDays    Int       @default(0)
  lastSignInDate String?
  inviteCode    String    @unique
  invitedBy     String?
  
  // Relations
  projects      Project[]
  aiLogs        AILog[]
  assets        Asset[]
  knowledgeItems KnowledgeItem[]
  pointsLogs    PointsLog[]
  rechargeRecords RechargeRecord[]
  adminLogs     AdminLog[]
  requirementSheets RequirementSheet[]
  userActionLogs UserActionLog[]
  
  createdAt2    DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("users")
}

// 项目模型
model Project {
  id          String   @id @default(cuid())
  name        String
  clientName  String
  status      String   @default("active")
  userId      String
  
  // Project step data (JSON storage)
  clientInfo   String?
  requirements String?
  competitors  String?
  brief       String?
  strategy    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("projects")
}

// AI日志
model AILog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  input       String
  output      String?
  pointsCost  Int      @default(0)
  status      String   @default("success")
  error       String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("ai_logs")
}

// 资产库
model Asset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  url         String?
  size        Int?
  mimeType    String?
  metadata    String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("assets")
}

// 知识库
model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  category    String?
  tags        String?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("knowledge_items")
}

// 积分流水记录
model PointsLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Int
  balance     Int
  reason      String
  orderNo     String?
  adminId     String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("points_logs")
}

// 充值记录
model RechargeRecord {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  points      Int
  paymentMethod String
  status      String   @default("pending")
  orderNo     String?
  remark      String?
  operatorId  String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("recharge_records")
}

// 管理员操作日志
model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  adminName   String
  action      String
  targetType  String
  targetId    String?
  detail      String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  
  @@map("admin_logs")
}

// 用户操作日志
model UserActionLog {
  id          String   @id @default(cuid())
  userId      String
  actionType  String
  targetType  String
  targetId    String?
  targetName  String?
  metadata    String?
  ip          String?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_action_logs")
}

// 访客会话表
model GuestSession {
  id        String   @id @default(cuid())
  token     String   @unique
  data      String?
  expireAt  DateTime
  createdAt DateTime @default(now()) @map("created_at")
  
  @@map("guest_sessions")
}

// 短信验证码记录
model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      String   @default("login")
  used      Boolean  @default(false)
  expireAt  DateTime
  createdAt DateTime @default(now()) @map("created_at")
  
  @@map("sms_codes")
}

// 需求确认单
model RequirementSheet {
  id          String   @id @default(cuid())
  userId      String
  projectName String
  clientName  String?
  items       String?
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("requirement_sheets")
}
